NEXT_PUBLIC_SUPABASE_URL=https://gfgqflrahwnbnqtdorly.supabase.co

# New Supabase naming (starts with sb_publishable_).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Legacy anon-key JWT — optional. Either one above or this works.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
